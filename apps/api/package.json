{
  "name": "@retailfixit/api",
  "version": "0.1.0",
  "private": true,
  "description": "RetailFixIt backend: REST API, event workflow, AI service, realtime gateway",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "npm run build && concurrently -k -n tsc,api -c blue,green \"tsc -p tsconfig.json --watch --preserveWatchOutput\" \"node --watch dist/index.js\"",
    "dev:once": "npm run build && node dist/index.js",
    "build": "npm run build -w @retailfixit/shared && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "clean": "rimraf dist",
    "db:bootstrap": "npm run build && node dist/db/bootstrap.js",
    "db:seed-beta": "npm run build && node dist/db/seed-tenant-beta-admin.js",
    "db:seed-platform": "npm run build && node dist/db/seed-platform-admin.js",
    "db:promote-platform": "npm run build && node dist/db/promote-platform-admin.js",
    "db:reset": "npm run build && node dist/db/reset-database.js"
  },
  "dependencies": {
    "@azure/cosmos": "^4.2.0",
    "@azure/service-bus": "^7.9.5",
    "@retailfixit/shared": "*",
    "applicationinsights": "^3.15.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.1.0",
    "pino": "^9.3.2",
    "pino-http": "^10.2.0",
    "uuid": "^10.0.0",
    "ws": "^8.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.14.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.1.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
