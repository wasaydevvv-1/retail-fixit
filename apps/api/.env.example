NODE_ENV=development
API_PORT=4000
API_BASE_PATH=/api/v1
CORS_ORIGIN=http://localhost:5173

# Auth
AUTH_DEV_JWT_SECRET=dev-only-change-me
# Set false to disable public vendor self-registration (POST /auth/register/vendor)
VENDOR_SELF_REGISTRATION_ENABLED=true
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_AUDIENCE=
# Optional: enables Entra user search/create in Admin → Add user (Graph API)
# Create a client secret on the API app registration, then grant Application permissions:
#   User.Read.All + User.ReadWrite.All + Application.Read.All + AppRoleAssignment.ReadWrite.All
# All need admin consent
AZURE_AD_CLIENT_SECRET=
# Optional override if Graph cannot read default domain (e.g. wasaydevvgmail.onmicrosoft.com)
AUTH_ENTRA_DEFAULT_DOMAIN=
# Business tenant assigned to users on first Entra login (admin assigns role in Entra)
AUTH_DEFAULT_TENANT_ID=tenant_acme

# Data (Azure Cosmos DB)
COSMOS_CONNECTION_STRING=
COSMOS_ENDPOINT=
COSMOS_KEY=
COSMOS_DATABASE=retailfixit

# Cache (optional in local dev — API runs without Redis; list caching is skipped)
REDIS_URL=redis://localhost:6379

# Events / realtime
# Assessment demo (recommended): service-bus + signalr + live OpenAI
EVENT_BUS_DRIVER=service-bus
SERVICE_BUS_CONNECTION_STRING=
SERVICE_BUS_QUEUE_NAME=retailfixit-events
REALTIME_DRIVER=signalr
SIGNALR_CONNECTION_STRING=

# Offline local dev only (no Azure Service Bus / SignalR):
# EVENT_BUS_DRIVER=in-memory
# REALTIME_DRIVER=local-ws

# AI
AI_USE_MOCK=false
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AI_REQUEST_TIMEOUT_MS=8000
AI_MAX_RETRIES=2

# Observability
LOG_LEVEL=info
# Optional: exports auto-request telemetry + custom metrics (ai_latency_ms, api_error_total, etc.)
APPLICATIONINSIGHTS_CONNECTION_STRING=
# Local metrics snapshot (no auth): GET /api/v1/observability/summary
# Admin UI: /admin/observability (System health)
