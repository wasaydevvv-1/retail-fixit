{
  "name": "@retailfixit/web",
  "version": "0.1.0",
  "private": true,
  "description": "RetailFixIt React SPA: job dashboard, detail, assignment, realtime updates",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@azure/msal-browser": "^3.26.1",
    "@microsoft/signalr": "^8.0.7",
    "@retailfixit/shared": "*",
    "@tanstack/react-query": "^5.51.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "vitest": "^2.0.5"
  }
}
