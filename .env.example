# ============================================================
# RetailFixIt - root environment template
# Copy to .env and fill in. App-specific overrides live in
# apps/api/.env and apps/web/.env
# ============================================================

NODE_ENV=development

# ---- API ----
API_PORT=4000
API_BASE_PATH=/api/v1

# ---- Auth (Azure AD / Entra ID) ----
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_AUDIENCE=
# For local dev a static JWT secret can be used instead of Entra ID
AUTH_DEV_JWT_SECRET=dev-only-change-me

# ---- Data store (Azure Cosmos DB) ----
COSMOS_CONNECTION_STRING=
COSMOS_ENDPOINT=
COSMOS_KEY=
COSMOS_DATABASE=retailfixit

# ---- Cache (Redis) ----
REDIS_URL=redis://localhost:6379

# ---- Event backbone (Azure Service Bus) ----
SERVICE_BUS_CONNECTION_STRING=
# When empty, an in-memory event bus is used for local dev
EVENT_BUS_DRIVER=in-memory

# ---- Real-time (Azure SignalR) ----
SIGNALR_CONNECTION_STRING=
# When empty, a local WebSocket server is used for local dev
REALTIME_DRIVER=local-ws

# ---- AI (Azure OpenAI) ----
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AI_REQUEST_TIMEOUT_MS=8000
AI_MAX_RETRIES=2
# When true, AI calls are mocked deterministically (no external call)
AI_USE_MOCK=true

# ---- Observability ----
APPLICATIONINSIGHTS_CONNECTION_STRING=
LOG_LEVEL=info
